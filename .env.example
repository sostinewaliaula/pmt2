# Caava Group - Project Management Tool Environment Variables

# Database Settings
POSTGRES_USER="caava"
POSTGRES_PASSWORD="caava_password"
POSTGRES_DB="caava_db"
PGDATA="/var/lib/postgresql/data"

# Redis Settings
REDIS_HOST="plane-redis"
REDIS_PORT="6379"

# RabbitMQ Settings
RABBITMQ_HOST="plane-mq"
RABBITMQ_PORT="5672"
RABBITMQ_USER="caava"
RABBITMQ_PASSWORD="caava_password"
RABBITMQ_VHOST="caava_vhost"

# Base URLs (Crucial for self-hosting)
# Example: http://192.168.1.10 or http://caava.example.com
WEB_URL=http://localhost
CORS_ALLOWED_ORIGINS=http://localhost

# Proxy/Port Settings
LISTEN_HTTP_PORT=80
LISTEN_HTTPS_PORT=443

# AWS / Storage Settings (Minio)
AWS_REGION=""
AWS_ACCESS_KEY_ID="caava-access-key"
AWS_SECRET_ACCESS_KEY="caava-secret-key"
AWS_S3_ENDPOINT_URL="http://plane-minio:9000"
AWS_S3_BUCKET_NAME="uploads"
# Maximum file upload limit (5MB default)
FILE_SIZE_LIMIT=5242880

# Application Settings
USE_MINIO=1
API_KEY_RATE_LIMIT="60/minute"

# SSL Settings
CERT_ACME_CA=https://acme-v02.api.letsencrypt.org/directory
TRUSTED_PROXIES=0.0.0.0/0
SITE_ADDRESS=:80
CERT_EMAIL=
MINIO_ENDPOINT_SSL=0
